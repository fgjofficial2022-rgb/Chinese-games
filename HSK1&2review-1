<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>⭐ Star Challenge · HSK Review</title>

    <style>
        /* ---------- 全局重置 & 清爽现代风格 ---------- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Georgia', 'Times New Roman', serif;
            background: linear-gradient(145deg, #e8f0fe 0%, #d4e4f7 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            /* 干净无磨砂，纯色渐变 */
            position: relative;
        }

        /* ---------- 主容器 ---------- */
        .container {
            width: 100%;
            max-width: 820px;
            background: #ffffff;
            border-radius: 32px;
            box-shadow: 0 20px 60px rgba(42, 125, 225, 0.12), 0 8px 24px rgba(0, 0, 0, 0.04);
            padding: 40px 44px 44px;
            position: relative;
            z-index: 1;
            border: 1px solid rgba(42, 125, 225, 0.08);
            transition: opacity 0.3s ease;
        }

        /* 印章装饰 — 简洁干净，只留一个小角标 */
        .container::after {
            content: '🏮 星';
            position: absolute;
            bottom: 16px;
            right: 20px;
            font-size: 13px;
            color: rgba(42, 125, 225, 0.20);
            letter-spacing: 1px;
            border: 1px solid rgba(42, 125, 225, 0.12);
            padding: 2px 12px 2px 10px;
            border-radius: 30px;
            font-family: 'Georgia', serif;
            background: rgba(255, 255, 255, 0.6);
            pointer-events: none;
        }

        /* ---------- 页面切换 ---------- */
        .page {
            display: none;
            opacity: 0;
            animation: fadeIn 0.40s ease forwards;
        }
        .page.active {
            display: block;
        }
        @keyframes fadeIn {
            0% {
                opacity: 0;
                transform: translateY(8px);
            }
            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ---------- 首页 ---------- */
        .home-title {
            text-align: center;
            margin-bottom: 4px;
        }
        .home-title h1 {
            font-size: 42px;
            font-weight: 700;
            letter-spacing: 2px;
            color: #1a2a4a;
            font-family: 'Georgia', 'Times New Roman', serif;
        }
        .home-title h1 .star-icon {
            color: #f5b342;
        }
        .home-title h1 .lantern {
            font-size: 36px;
            display: inline-block;
            margin: 0 6px;
        }
        .home-sub {
            text-align: center;
            font-size: 18px;
            color: #5a7a9a;
            letter-spacing: 4px;
            margin-top: 4px;
            font-weight: 400;
            border-bottom: 1px solid rgba(42, 125, 225, 0.12);
            padding-bottom: 24px;
        }

        .group-list {
            display: flex;
            flex-direction: column;
            gap: 18px;
            margin-top: 32px;
        }

        .group-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 24px;
            background: #f8faff;
            border-radius: 16px;
            border: 1px solid rgba(42, 125, 225, 0.10);
            transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
        }
        .group-item:hover {
            background: #f0f6ff;
            border-color: rgba(42, 125, 225, 0.25);
            box-shadow: 0 4px 16px rgba(42, 125, 225, 0.06);
        }

        .group-btn-wrap {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .group-btn {
            font-size: 22px;
            font-weight: 700;
            color: #1a2a4a;
            background: transparent;
            border: 2px solid #2a7de1;
            border-radius: 14px;
            padding: 10px 36px;
            cursor: pointer;
            transition: all 0.20s ease;
            letter-spacing: 2px;
            font-family: 'Georgia', serif;
            background: #ffffff;
            min-width: 80px;
            text-align: center;
            display: flex;
            align-items: center;
            gap: 8px;
            justify-content: center;
        }
        .group-btn .emoji-icon {
            font-size: 24px;
            line-height: 1;
        }
        .group-btn:hover {
            background: #2a7de1;
            color: #ffffff;
            transform: scale(1.02);
            box-shadow: 0 6px 20px rgba(42, 125, 225, 0.30);
            border-color: #2a7de1;
        }
        .group-btn:active {
            transform: scale(0.97);
        }
        .group-btn.completed {
            border-color: #f5b342;
            color: #f5b342;
        }
        .group-btn.completed:hover {
            background: #f5b342;
            color: #ffffff;
            border-color: #f5b342;
        }

        .group-stars {
            font-size: 20px;
            color: #f5b342;
            letter-spacing: 1px;
            font-weight: 600;
            min-width: 60px;
            text-align: right;
            font-family: 'Georgia', serif;
        }

        /* ---------- 游戏页面 ---------- */
        .game-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            border-bottom: 1px solid rgba(42, 125, 225, 0.10);
            padding-bottom: 14px;
            margin-bottom: 18px;
        }
        .game-header .game-title {
            font-size: 22px;
            font-weight: 700;
            color: #1a2a4a;
            letter-spacing: 1px;
        }
        .game-header .game-title .star-icon {
            color: #f5b342;
        }
        .game-header .game-progress {
            font-size: 18px;
            color: #5a7a9a;
            font-weight: 400;
        }

        .question-meta {
            display: flex;
            align-items: baseline;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 8px;
            margin-top: 2px;
        }
        .question-module {
            font-size: 16px;
            color: #2a7de1;
            background: rgba(42, 125, 225, 0.08);
            padding: 2px 16px;
            border-radius: 20px;
            letter-spacing: 0.5px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .question-module .module-icon {
            font-size: 18px;
        }
        .question-hint {
            font-size: 14px; /* 更小 */
            color: #7a9ab0;
            font-weight: 400;
            font-style: italic;
            letter-spacing: 0.3px;
            background: rgba(0, 0, 0, 0.02);
            padding: 0 8px;
            border-radius: 12px;
        }

        .question-text {
            font-size: 28px;
            line-height: 1.6;
            color: #1a2a4a;
            font-weight: 500;
            letter-spacing: 0.5px;
            white-space: pre-wrap;
            word-break: break-word;
            font-family: 'KaiTi', '楷体', serif;
            padding: 6px 0 10px;
        }
        .question-text .highlight {
            color: #c41a1a;
            font-weight: 600;
        }

        /* 倒计时区域 */
        .timer-section {
            margin: 20px 0 18px;
            padding: 18px 20px 16px;
            background: #f8faff;
            border-radius: 16px;
            border: 1px solid rgba(42, 125, 225, 0.08);
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 12px 16px;
        }
        .timer-buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        .timer-btn {
            font-size: 18px;
            font-weight: 600;
            color: #1a2a4a;
            background: #ffffff;
            border: 2px solid #2a7de1;
            border-radius: 10px;
            padding: 6px 18px;
            cursor: pointer;
            transition: all 0.15s ease;
            font-family: 'Georgia', serif;
            min-width: 56px;
            text-align: center;
        }
        .timer-btn:hover:not(:disabled) {
            background: #2a7de1;
            color: #fff;
            transform: scale(1.04);
            box-shadow: 0 4px 14px rgba(42, 125, 225, 0.25);
        }
        .timer-btn:active:not(:disabled) {
            transform: scale(0.95);
        }
        .timer-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }

        .timer-display {
            font-size: 32px;
            font-weight: 700;
            color: #1a2a4a;
            min-width: 120px;
            text-align: center;
            font-family: 'Georgia', serif;
            letter-spacing: 2px;
            padding: 4px 0;
        }
        .timer-display.time-up {
            color: #e74c3c;
            animation: pulseRed 0.6s ease 2;
        }
        @keyframes pulseRed {
            0%,
            100% {
                opacity: 1;
            }
            50% {
                opacity: 0.4;
            }
        }
        .timer-status {
            font-size: 15px;
            color: #5a7a9a;
            margin-left: auto;
            font-weight: 400;
        }

        /* 五星评分 */
        .stars-section {
            display: flex;
            align-items: center;
            gap: 18px;
            margin: 14px 0 22px;
            padding: 10px 0;
            flex-wrap: wrap;
        }
        .stars-label {
            font-size: 18px;
            color: #5a7a9a;
            font-weight: 400;
            letter-spacing: 0.5px;
        }
        .stars-container {
            display: flex;
            gap: 8px;
            font-size: 44px;
            line-height: 1;
            cursor: pointer;
            user-select: none;
        }
        .star-item {
            color: #d0dce8;
            transition: all 0.15s ease;
            display: inline-block;
            line-height: 1;
        }
        .star-item.lit {
            color: #f5b342;
            text-shadow: 0 0 12px rgba(245, 179, 66, 0.40), 0 0 24px rgba(245, 179, 66, 0.15);
            animation: starPop 0.30s ease;
        }
        @keyframes starPop {
            0% {
                transform: scale(1);
            }
            40% {
                transform: scale(1.30);
            }
            100% {
                transform: scale(1);
            }
        }
        .star-item:hover {
            transform: scale(1.12);
        }

        /* 导航按钮区域 */
        .nav-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            border-top: 1px solid rgba(42, 125, 225, 0.10);
            padding-top: 22px;
            margin-top: 4px;
        }
        .btn-prev,
        .btn-next {
            font-size: 18px;
            font-weight: 600;
            color: #ffffff;
            background: #2a7de1;
            border: none;
            border-radius: 14px;
            padding: 10px 34px;
            cursor: pointer;
            transition: all 0.20s ease;
            font-family: 'Georgia', serif;
            letter-spacing: 1px;
            box-shadow: 0 4px 14px rgba(42, 125, 225, 0.20);
        }
        .btn-prev {
            background: #7a9ab0;
            box-shadow: 0 4px 14px rgba(90, 120, 140, 0.15);
        }
        .btn-prev:hover:not(:disabled) {
            background: #5a7a90;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(90, 120, 140, 0.20);
        }
        .btn-next:hover:not(:disabled) {
            background: #1a5fc0;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(42, 125, 225, 0.30);
        }
        .btn-prev:disabled,
        .btn-next:disabled {
            opacity: 0.35;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }

        /* ---------- 成绩页面 ---------- */
        .result-wrap {
            text-align: center;
            padding: 8px 0 4px;
        }
        .result-title {
            font-size: 40px;
            font-weight: 700;
            color: #1a2a4a;
            letter-spacing: 1px;
        }
        .result-title .star-icon {
            color: #f5b342;
        }
        .result-title .lantern {
            font-size: 32px;
            display: inline-block;
            margin: 0 6px;
        }
        .result-sub {
            font-size: 22px;
            color: #5a7a9a;
            margin-top: 8px;
            font-weight: 400;
        }

        .result-stars-display {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 6px 10px;
            font-size: 42px;
            line-height: 1.4;
            margin: 18px 0 6px;
            padding: 12px 10px;
            min-height: 70px;
            background: rgba(248, 250, 255, 0.6);
            border-radius: 20px;
            border: 1px solid rgba(42, 125, 225, 0.06);
        }
        .result-stars-display .star-unit {
            color: #d0dce8;
            transition: color 0.15s ease, text-shadow 0.15s ease;
        }
        .result-stars-display .star-unit.lit {
            color: #f5b342;
            text-shadow: 0 0 12px rgba(245, 179, 66, 0.40);
        }

        .result-score {
            font-size: 30px;
            font-weight: 700;
            color: #f5b342;
            margin: 6px 0 12px;
            letter-spacing: 1px;
        }
        .result-score .num {
            font-size: 44px;
        }

        .result-encourage {
            font-size: 22px;
            color: #1a2a4a;
            font-weight: 400;
            margin: 8px 0 18px;
            font-style: italic;
            letter-spacing: 0.5px;
        }

        .answer-review {
            margin-top: 24px;
            text-align: left;
            border-top: 1px solid rgba(42, 125, 225, 0.10);
            padding-top: 20px;
        }
        .answer-review h3 {
            font-size: 18px;
            color: #5a7a9a;
            font-weight: 400;
            letter-spacing: 2px;
            margin-bottom: 14px;
            text-align: center;
        }
        .answer-review .answer-item {
            display: flex;
            gap: 12px;
            padding: 8px 10px;
            border-bottom: 1px solid rgba(42, 125, 225, 0.05);
            font-size: 15px;
            line-height: 1.6;
            font-family: 'KaiTi', '楷体', serif;
        }
        .answer-review .answer-item .q-num {
            font-weight: 600;
            color: #7a9ab0;
            min-width: 36px;
            font-family: 'Georgia', serif;
        }
        .answer-review .answer-item .q-text {
            color: #1a2a4a;
            flex: 1;
        }
        .answer-review .answer-item .q-answer {
            color: #5a7a9a;
            font-style: italic;
            max-width: 45%;
            text-align: right;
        }

        .btn-return {
            font-size: 20px;
            font-weight: 600;
            color: #1a2a4a;
            background: transparent;
            border: 2px solid #2a7de1;
            border-radius: 14px;
            padding: 12px 44px;
            cursor: pointer;
            transition: all 0.20s ease;
            font-family: 'Georgia', serif;
            letter-spacing: 1px;
            margin-top: 18px;
            background: #ffffff;
        }
        .btn-return:hover {
            background: #2a7de1;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(42, 125, 225, 0.20);
            border-color: #2a7de1;
        }
        .btn-return:active {
            transform: scale(0.97);
        }

        /* ---------- 响应式 ---------- */
        @media (max-width: 650px) {
            .container {
                padding: 24px 18px 28px;
                border-radius: 24px;
            }
            .home-title h1 {
                font-size: 30px;
            }
            .home-title h1 .lantern {
                font-size: 26px;
            }
            .home-sub {
                font-size: 15px;
                letter-spacing: 2px;
                padding-bottom: 18px;
            }
            .group-btn {
                font-size: 18px;
                padding: 8px 22px;
                min-width: 60px;
            }
            .group-btn .emoji-icon {
                font-size: 20px;
            }
            .group-stars {
                font-size: 17px;
                min-width: 44px;
            }
            .game-header .game-title {
                font-size: 18px;
            }
            .game-header .game-progress {
                font-size: 15px;
            }
            .question-text {
                font-size: 22px;
            }
            .question-hint {
                font-size: 13px;
            }
            .timer-display {
                font-size: 26px;
                min-width: 80px;
            }
            .timer-btn {
                font-size: 15px;
                padding: 4px 14px;
                min-width: 44px;
            }
            .stars-container {
                font-size: 34px;
                gap: 4px;
            }
            .btn-prev,
            .btn-next {
                font-size: 16px;
                padding: 8px 24px;
            }
            .result-title {
                font-size: 30px;
            }
            .result-title .lantern {
                font-size: 24px;
            }
            .result-stars-display {
                font-size: 32px;
                gap: 4px 8px;
            }
            .result-score {
                font-size: 24px;
            }
            .result-score .num {
                font-size: 34px;
            }
            .answer-review .answer-item {
                flex-wrap: wrap;
                gap: 4px 8px;
            }
            .answer-review .answer-item .q-answer {
                max-width: 100%;
                text-align: left;
                padding-left: 36px;
            }
            .container::after {
                display: none;
            }
        }

        @media (max-width: 420px) {
            .container {
                padding: 16px 12px 20px;
            }
            .group-item {
                padding: 10px 14px;
                flex-wrap: wrap;
                gap: 8px;
            }
            .group-btn-wrap {
                width: 100%;
                justify-content: space-between;
            }
            .timer-section {
                flex-direction: column;
                align-items: stretch;
            }
            .timer-buttons {
                justify-content: center;
            }
            .timer-display {
                font-size: 28px;
            }
            .timer-status {
                margin-left: 0;
                text-align: center;
            }
            .stars-section {
                justify-content: center;
            }
            .nav-row {
                flex-direction: column-reverse;
                align-items: stretch;
            }
            .btn-prev,
            .btn-next {
                width: 100%;
                text-align: center;
            }
        }

        /* 工具 */
        .text-center {
            text-align: center;
        }
        .hidden {
            display: none !important;
        }
    </style>
</head>

<body>

    <div class="container" id="app">

        <!-- ========== 首页 ========== -->
        <div class="page active" id="pageHome">
            <div class="home-title">
                <h1>
                    <span class="lantern">🏮</span>
                    <span class="star-icon">⭐</span> Star Challenge
                    <span class="lantern">🏮</span>
                </h1>
            </div>
            <div class="home-sub">HSK 1 &amp; HSK 2 Review</div>

            <div class="group-list" id="groupList">
                <!-- JS动态生成 -->
            </div>
            <div style="text-align:center;margin-top:28px;font-size:13px;color:rgba(42,125,225,0.20);letter-spacing:6px;font-family:'Georgia',serif;">
                · 课堂互动 ·
            </div>
        </div>

        <!-- ========== 游戏页面 ========== -->
        <div class="page" id="pageGame">
            <div class="game-header">
                <span class="game-title"><span class="star-icon">⭐</span> Star Challenge</span>
                <span class="game-progress" id="gameProgress">Question 1 / 8</span>
            </div>

            <!-- 模块 & 提示 -->
            <div class="question-meta">
                <span class="question-module" id="gameModule">
                    <span class="module-icon">📖</span> Pronunciation
                </span>
                <span class="question-hint" id="gameHint">(提示)</span>
            </div>

            <div class="question-text" id="questionText">题目加载中…</div>

            <!-- 倒计时 -->
            <div class="timer-section">
                <div class="timer-buttons" id="timerButtons">
                    <button class="timer-btn" data-seconds="3">3s</button>
                    <button class="timer-btn" data-seconds="5">5s</button>
                    <button class="timer-btn" data-seconds="8">8s</button>
                    <button class="timer-btn" data-seconds="10">10s</button>
                </div>
                <div class="timer-display" id="timerDisplay">⏱</div>
                <div class="timer-status" id="timerStatus">选择时间</div>
            </div>

            <!-- 五星评分 -->
            <div class="stars-section">
                <span class="stars-label">评分</span>
                <div class="stars-container" id="starsContainer">
                    <span class="star-item" data-index="0">★</span>
                    <span class="star-item" data-index="1">★</span>
                    <span class="star-item" data-index="2">★</span>
                    <span class="star-item" data-index="3">★</span>
                    <span class="star-item" data-index="4">★</span>
                </div>
            </div>

            <!-- 导航按钮 -->
            <div class="nav-row">
                <button class="btn-prev" id="btnPrev" disabled>← Previous</button>
                <button class="btn-next" id="btnNext" disabled>Next →</button>
            </div>
        </div>

        <!-- ========== 成绩页面 ========== -->
        <div class="page" id="pageResult">
            <div class="result-wrap">
                <div class="result-title">
                    <span class="lantern">🏮</span>
                    <span class="star-icon">⭐</span> Congratulations!
                    <span class="lantern">🏮</span>
                </div>
                <div class="result-sub">You earned</div>

                <div class="result-stars-display" id="resultStarsDisplay">
                    <!-- 星星动画渲染到这里 -->
                </div>

                <div class="result-score">
                    <span class="num" id="resultScoreNum">0</span> stars!
                </div>

                <div class="result-encourage" id="resultEncourage">🌟 Keep going!</div>

                <!-- 参考答案列表 -->
                <div class="answer-review" id="answerReview">
                    <h3>📖 参考答案</h3>
                    <div id="answerList"></div>
                </div>

                <button class="btn-return" id="btnReturnHome">🏠 Return Home</button>
            </div>
        </div>

    </div>

    <script>
        /**
         * =============================================================
         * 一、数据层 —— 集中管理所有题目
         * 修改了三个题目的参考答案（A组第8题、B组第6题、C组第8题）
         * =============================================================
         */
        const GROUPS_DATA = {

            A: {
                id: 'A',
                label: 'A',
                icon: '🐉',
                questions: [{
                    module: 'Pronunciation',
                    hint: 'Read aloud',
                    question: 'üe',
                    answer: 'üe （发音类似 "约"）'
                }, {
                    module: 'Vocabulary',
                    hint: 'Say the word',
                    question: '"name" in Chinese.',
                    answer: '名字 (míngzi)'
                }, {
                    module: 'Reading',
                    hint: 'Read aloud and translate',
                    question: '电脑',
                    answer: '电脑 (diànnǎo) — computer'
                }, {
                    module: 'Fixed Expressions',
                    hint: 'Complete the dialogue',
                    question: '-- 谢谢你。\n-- _________。',
                    answer: '不客气 (bú kèqi)'
                }, {
                    module: 'Translation',
                    hint: 'Translate into English',
                    question: '这个西瓜15块钱。\nPlease translate the sentence into English.',
                    answer: 'This watermelon is 15 yuan.'
                }, {
                    module: 'Speaking',
                    hint: 'Answer in Chinese',
                    question: '-- What time is it now?\nPlease answer in Chinese.\n-- _________________。',
                    answer: '现在几点了？(xiànzài jǐ diǎn le?)'
                }, {
                    module: 'Speaking',
                    hint: 'Respond in Chinese',
                    question: '我喜欢看电影，你呢？\n-- __________。',
                    answer: '我也喜欢看电影。/ 我不喜欢看电影。'
                }, {
                    module: 'Grammar',
                    hint: 'Fill in the blank with 几 or 多',
                    question: 'Complete the sentence using 几 or 多：\nThere are more than fifty students at the school.',
                    answer: '学校有五十几/多个学生。'   // 修改为更准确的表达
                }]
            },

            B: {
                id: 'B',
                label: 'B',
                icon: '🐼',
                questions: [{
                    module: 'Pronunciation',
                    hint: 'Read aloud',
                    question: 'ui',
                    answer: 'ui （发音类似 "微"）'
                }, {
                    module: 'Vocabulary',
                    hint: 'Say the word',
                    question: '"friend" in Chinese.',
                    answer: '朋友 (péngyou)'
                }, {
                    module: 'Reading',
                    hint: 'Read aloud and translate',
                    question: '医院',
                    answer: '医院 (yīyuàn) — hospital'
                }, {
                    module: 'Fixed Expressions',
                    hint: 'Complete the dialogue',
                    question: '-- 对不起。\n-- __________。',
                    answer: '没关系 (méi guānxi)'
                }, {
                    module: 'Translation',
                    hint: 'Translate into English',
                    question: '今天是7月9号。\nPlease translate the sentence into English.',
                    answer: 'Today is July 9th.'
                }, {
                    module: 'Speaking',
                    hint: 'Answer in Chinese',
                    question: '-- What\'s your favourite food?\nPlease answer in Chinese.\n-- _________________。',
                    answer: '我最喜欢吃……'   // 修改为更自然的表达
                }, {
                    module: 'Speaking',
                    hint: 'Respond in Chinese',
                    question: '明天天气怎么样？\n-- __________。',
                    answer: '明天天气很好。/ 明天会下雨。'
                }, {
                    module: 'Grammar',
                    hint: 'Fill in the blank with 几',
                    question: 'Complete the sentence using 几：\nThere are several apples on the table.',
                    answer: '桌子上有几个苹果。'
                }]
            },

            C: {
                id: 'C',
                label: 'C',
                icon: '🏮',
                questions: [{
                    module: 'Pronunciation',
                    hint: 'Read aloud',
                    question: 'ün',
                    answer: 'ün （发音类似 "晕"）'
                }, {
                    module: 'Vocabulary',
                    hint: 'Say the word',
                    question: '"classmate" in Chinese.',
                    answer: '同学 (tóngxué)'
                }, {
                    module: 'Reading',
                    hint: 'Read aloud and translate',
                    question: '衣服',
                    answer: '衣服 (yīfu) — clothes'
                }, {
                    module: 'Fixed Expressions',
                    hint: 'Complete the dialogue',
                    question: '-- 再见。\n-- __________。',
                    answer: '再见 (zàijiàn)'
                }, {
                    module: 'Translation',
                    hint: 'Translate into English',
                    question: '我不会说英语。\nPlease translate the sentence into English.',
                    answer: 'I can\'t speak English.'
                }, {
                    module: 'Speaking',
                    hint: 'Answer in Chinese',
                    question: '-- What day is it today?\nPlease answer in Chinese.\n-- _________________。',
                    answer: '今天星期几？(jīntiān xīngqī jǐ?)'
                }, {
                    module: 'Speaking',
                    hint: 'Respond in Chinese',
                    question: '你昨天去哪儿了？\n-- __________。',
                    answer: '我去……了。'
                }, {
                    module: 'Grammar',
                    hint: 'Fill in the blank with 几 or 多',
                    question: 'Complete the sentence using 几 or 多：\nThere are more than ten people in my family.',
                    answer: '我家有十几/多口人。'   // 修改为更准确的表达
                }]
            }
        };

        /**
         * =============================================================
         * 二、状态管理
         * =============================================================
         */
        const state = {
            currentGroupId: null,
            currentIndex: 0,
            scoresPerGroup: { A: [], B: [], C: [] },
            completed: { A: false, B: false, C: false },
            currentRating: 0,
            timer: {
                seconds: 0,
                running: false,
                intervalId: null,
                ended: false
            },
            transitioning: false
        };

        function initScores() {
            for (const gid of ['A', 'B', 'C']) {
                const len = GROUPS_DATA[gid].questions.length;
                state.scoresPerGroup[gid] = new Array(len).fill(0);
            }
        }
        initScores();

        /**
         * =============================================================
         * 三、DOM 引用
         * =============================================================
         */
        const $ = (id) => document.getElementById(id);
        const dom = {
            pageHome: $('pageHome'),
            pageGame: $('pageGame'),
            pageResult: $('pageResult'),
            groupList: $('groupList'),
            gameProgress: $('gameProgress'),
            gameModule: $('gameModule'),
            gameHint: $('gameHint'),
            questionText: $('questionText'),
            timerButtons: $('timerButtons'),
            timerDisplay: $('timerDisplay'),
            timerStatus: $('timerStatus'),
            starsContainer: $('starsContainer'),
            btnPrev: $('btnPrev'),
            btnNext: $('btnNext'),
            resultStarsDisplay: $('resultStarsDisplay'),
            resultScoreNum: $('resultScoreNum'),
            resultEncourage: $('resultEncourage'),
            answerList: $('answerList'),
            btnReturnHome: $('btnReturnHome'),
        };

        /**
         * =============================================================
         * 四、工具函数
         * =============================================================
         */

        /** Beep 提示音 */
        function playBeep() {
            try {
                const ctx = new(window.AudioContext || window.webkitAudioContext)();
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain);
                gain.connect(ctx.destination);
                osc.type = 'sine';
                osc.frequency.value = 880;
                gain.gain.value = 0.25;
                gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.25);
                osc.start(ctx.currentTime);
                osc.stop(ctx.currentTime + 0.25);
            } catch (_) { /* 静默 */ }
        }

        /** 欢呼声 — 更丰富、更清晰 */
        function playCelebration() {
            try {
                const ctx = new(window.AudioContext || window.webkitAudioContext)();
                // 上行音阶 + 和弦效果
                const notes = [523, 587, 659, 784, 880, 988, 1175]; // C5 ~ D6
                notes.forEach((freq, i) => {
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.type = 'sine';
                    osc.frequency.value = freq;
                    gain.gain.value = 0.15;
                    gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.2 + i * 0.08);
                    osc.start(ctx.currentTime + i * 0.08);
                    osc.stop(ctx.currentTime + i * 0.08 + 0.2);
                });
                // 额外加一个高音点缀
                setTimeout(() => {
                    const osc2 = ctx.createOscillator();
                    const gain2 = ctx.createGain();
                    osc2.connect(gain2);
                    gain2.connect(ctx.destination);
                    osc2.type = 'sine';
                    osc2.frequency.value = 1319; // E6
                    gain2.gain.value = 0.12;
                    gain2.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.3);
                    osc2.start(ctx.currentTime + 0.3);
                    osc2.stop(ctx.currentTime + 0.5);
                }, 600);
            } catch (_) { /* 静默 */ }
        }

        function getGroupQuestions(groupId) {
            return GROUPS_DATA[groupId]?.questions || [];
        }

        function getCurrentQuestions() {
            return getGroupQuestions(state.currentGroupId);
        }

        function getCurrentQuestion() {
            const qs = getCurrentQuestions();
            return qs[state.currentIndex] || null;
        }

        function getGroupScores(groupId) {
            return state.scoresPerGroup[groupId] || [];
        }

        function calcTotalStars(groupId) {
            const arr = state.scoresPerGroup[groupId] || [];
            return arr.reduce((a, b) => a + b, 0);
        }

        function getEncouragement(score) {
            if (score >= 36) return '🌟 Outstanding! You\'re a star! 🌟';
            if (score >= 28) return '✨ Great job! Keep shining! ✨';
            if (score >= 18) return '💪 Good effort! Practice makes perfect! 💪';
            if (score >= 8) return '📚 Keep going! You can do it! 📚';
            return '🌱 Every step counts! Keep learning! 🌱';
        }

        /** 根据模块返回对应的图标 */
        function getModuleIcon(module) {
            const map = {
                'Pronunciation': '🔊',
                'Vocabulary': '📝',
                'Reading': '📖',
                'Fixed Expressions': '✏️',
                'Translation': '🌍',
                'Speaking': '🗣️',
                'Grammar': '📐'
            };
            return map[module] || '📌';
        }

        /**
         * =============================================================
         * 五、渲染函数
         * =============================================================
         */

        function renderHome() {
            const list = dom.groupList;
            list.innerHTML = '';
            const groupIds = ['A', 'B', 'C'];
            groupIds.forEach((gid) => {
                const group = GROUPS_DATA[gid];
                const item = document.createElement('div');
                item.className = 'group-item';
                const wrap = document.createElement('div');
                wrap.className = 'group-btn-wrap';
                const btn = document.createElement('button');
                btn.className = 'group-btn';
                if (state.completed[gid]) btn.classList.add('completed');
                // 加入中国风图标
                const iconSpan = document.createElement('span');
                iconSpan.className = 'emoji-icon';
                iconSpan.textContent = group.icon || '🎯';
                btn.appendChild(iconSpan);
                btn.appendChild(document.createTextNode(gid));
                btn.dataset.group = gid;
                btn.addEventListener('click', () => startGroup(gid));

                const starsSpan = document.createElement('span');
                starsSpan.className = 'group-stars';
                if (state.completed[gid]) {
                    const total = calcTotalStars(gid);
                    starsSpan.textContent = '⭐' + total;
                } else {
                    starsSpan.textContent = '';
                }
                wrap.appendChild(btn);
                wrap.appendChild(starsSpan);
                item.appendChild(wrap);
                const hint = document.createElement('span');
                hint.style.cssText =
                    'font-size:13px;color:rgba(42,125,225,0.25);letter-spacing:1px;font-style:italic;';
                hint.textContent = state.completed[gid] ? '已完成' : '—';
                item.appendChild(hint);
                list.appendChild(item);
            });
        }

        function renderQuestion() {
            const q = getCurrentQuestion();
            if (!q) {
                dom.questionText.textContent = '题目加载失败';
                return;
            }
            const total = getCurrentQuestions().length;
            dom.gameProgress.textContent = `Question ${state.currentIndex + 1} / ${total}`;
            // 模块带图标
            const icon = getModuleIcon(q.module);
            dom.gameModule.innerHTML = `<span class="module-icon">${icon}</span> ${q.module}`;
            dom.gameHint.textContent = q.hint || '';
            dom.questionText.textContent = q.question;

            const scores = getGroupScores(state.currentGroupId);
            const saved = scores[state.currentIndex] || 0;
            state.currentRating = saved;
            updateStarsUI(saved);
            dom.btnNext.disabled = (saved === 0);
            dom.btnPrev.disabled = (state.currentIndex === 0);

            if (state.currentIndex === total - 1) {
                dom.btnNext.textContent = 'Finish ✓';
            } else {
                dom.btnNext.textContent = 'Next →';
            }
            resetTimer();
        }

        function updateStarsUI(rating) {
            const items = dom.starsContainer.querySelectorAll('.star-item');
            items.forEach((el, idx) => {
                if (idx < rating) {
                    el.classList.add('lit');
                } else {
                    el.classList.remove('lit');
                }
            });
            dom.btnNext.disabled = (rating === 0);
        }

        function resetTimer() {
            const t = state.timer;
            if (t.intervalId) {
                clearInterval(t.intervalId);
                t.intervalId = null;
            }
            t.running = false;
            t.ended = false;
            t.seconds = 0;
            dom.timerDisplay.textContent = '⏱';
            dom.timerDisplay.classList.remove('time-up');
            dom.timerStatus.textContent = '选择时间';
            const btns = dom.timerButtons.querySelectorAll('.timer-btn');
            btns.forEach((b) => b.disabled = false);
        }

        function startTimer(seconds) {
            const t = state.timer;
            if (t.intervalId) {
                clearInterval(t.intervalId);
                t.intervalId = null;
            }
            t.running = true;
            t.ended = false;
            t.seconds = seconds;
            const btns = dom.timerButtons.querySelectorAll('.timer-btn');
            btns.forEach((b) => b.disabled = true);
            dom.timerDisplay.textContent = seconds;
            dom.timerDisplay.classList.remove('time-up');
            dom.timerStatus.textContent = '倒计时中…';

            let remaining = seconds;
            t.intervalId = setInterval(() => {
                remaining -= 1;
                if (remaining <= 0) {
                    clearInterval(t.intervalId);
                    t.intervalId = null;
                    t.running = false;
                    t.ended = true;
                    dom.timerDisplay.textContent = "Time's up!";
                    dom.timerDisplay.classList.add('time-up');
                    dom.timerStatus.textContent = '时间到';
                    playBeep();
                    const btns2 = dom.timerButtons.querySelectorAll('.timer-btn');
                    btns2.forEach((b) => b.disabled = false);
                } else {
                    dom.timerDisplay.textContent = remaining;
                }
            }, 1000);
        }

        function renderResult(groupId) {
            const total = calcTotalStars(groupId);
            const qs = getGroupQuestions(groupId);

            const container = dom.resultStarsDisplay;
            container.innerHTML = '';
            for (let i = 0; i < total; i++) {
                const span = document.createElement('span');
                span.className = 'star-unit lit';
                span.textContent = '⭐';
                container.appendChild(span);
            }
            dom.resultScoreNum.textContent = total;
            dom.resultEncourage.textContent = getEncouragement(total);

            const list = dom.answerList;
            list.innerHTML = '';
            qs.forEach((q, idx) => {
                const item = document.createElement('div');
                item.className = 'answer-item';
                const num = document.createElement('span');
                num.className = 'q-num';
                num.textContent = `${idx+1}.`;
                const text = document.createElement('span');
                text.className = 'q-text';
                text.textContent = q.question;
                const ans = document.createElement('span');
                ans.className = 'q-answer';
                ans.textContent = q.answer;
                item.appendChild(num);
                item.appendChild(text);
                item.appendChild(ans);
                list.appendChild(item);
            });

            // 播放欢呼声
            playCelebration();
        }

        /**
         * =============================================================
         * 六、页面切换
         * =============================================================
         */
        function showPage(pageId) {
            ['pageHome', 'pageGame', 'pageResult'].forEach((id) => {
                const el = $(id);
                if (id === pageId) {
                    el.classList.add('active');
                    el.style.animation = 'none';
                    requestAnimationFrame(() => { el.style.animation = ''; });
                } else {
                    el.classList.remove('active');
                    el.style.animation = '';
                }
            });
        }

        /**
         * =============================================================
         * 七、核心业务逻辑
         * =============================================================
         */
        function startGroup(groupId) {
            if (state.transitioning) return;
            if (state.completed[groupId]) {
                if (!confirm(`Group ${groupId} 已完成，是否重新开始？`)) return;
                const len = GROUPS_DATA[groupId].questions.length;
                state.scoresPerGroup[groupId] = new Array(len).fill(0);
                state.completed[groupId] = false;
                renderHome();
            }
            state.currentGroupId = groupId;
            state.currentIndex = 0;
            state.currentRating = 0;
            resetTimer();
            showPage('pageGame');
            renderQuestion();
            renderHome();
        }

        function goPrev() {
            if (state.transitioning) return;
            if (state.currentIndex === 0) return;
            const scores = getGroupScores(state.currentGroupId);
            scores[state.currentIndex] = 0;
            state.currentIndex--;
            scores[state.currentIndex] = 0;
            state.currentRating = 0;
            resetTimer();
            renderQuestion();
        }

        function goNext() {
            if (state.transitioning) return;
            if (state.currentRating === 0) {
                dom.starsContainer.style.animation = 'pulseRed 0.4s ease 2';
                setTimeout(() => { dom.starsContainer.style.animation = ''; }, 900);
                return;
            }
            const scores = getGroupScores(state.currentGroupId);
            scores[state.currentIndex] = state.currentRating;

            const qs = getCurrentQuestions();
            const total = qs.length;

            if (state.currentIndex >= total - 1) {
                const gid = state.currentGroupId;
                state.completed[gid] = true;
                showPage('pageResult');
                renderResult(gid);
                renderHome();
                return;
            }

            state.currentIndex++;
            scores[state.currentIndex] = 0;
            state.currentRating = 0;
            resetTimer();
            renderQuestion();
        }

        function handleStarClick(index) {
            const rating = index + 1;
            state.currentRating = rating;
            const scores = getGroupScores(state.currentGroupId);
            scores[state.currentIndex] = rating;
            updateStarsUI(rating);
            dom.btnNext.disabled = false;
        }

        function handleTimerClick(seconds) {
            const t = state.timer;
            if (t.running || t.ended) {
                if (t.intervalId) {
                    clearInterval(t.intervalId);
                    t.intervalId = null;
                }
                t.running = false;
                t.ended = false;
                dom.timerDisplay.classList.remove('time-up');
            }
            startTimer(seconds);
        }

        function goHome() {
            if (state.transitioning) return;
            if (state.timer.intervalId) {
                clearInterval(state.timer.intervalId);
                state.timer.intervalId = null;
                state.timer.running = false;
            }
            showPage('pageHome');
            renderHome();
        }

        /**
         * =============================================================
         * 八、事件绑定
         * =============================================================
         */
        dom.timerButtons.addEventListener('click', (e) => {
            const btn = e.target.closest('.timer-btn');
            if (!btn || btn.disabled) return;
            const sec = parseInt(btn.dataset.seconds, 10);
            if (isNaN(sec) || sec < 1) return;
            handleTimerClick(sec);
        });

        dom.starsContainer.addEventListener('click', (e) => {
            const star = e.target.closest('.star-item');
            if (!star) return;
            const idx = parseInt(star.dataset.index, 10);
            if (isNaN(idx)) return;
            handleStarClick(idx);
        });

        dom.btnNext.addEventListener('click', goNext);
        dom.btnPrev.addEventListener('click', goPrev);
        dom.btnReturnHome.addEventListener('click', goHome);

        /**
         * =============================================================
         * 九、初始化
         * =============================================================
         */
        function init() {
            state.currentGroupId = null;
            state.currentIndex = 0;
            state.completed = { A: false, B: false, C: false };
            state.transitioning = false;
            initScores();
            resetTimer();
            showPage('pageHome');
            renderHome();
            updateStarsUI(0);
            dom.btnNext.disabled = true;
            dom.btnPrev.disabled = true;
            console.log('⭐ Star Challenge 已启动！数据集中管理于 GROUPS_DATA。');
        }

        init();
    </script>

